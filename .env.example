# ─────────────── База данных ───────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/stelar?schema=public"

# ─────────────── JWT ───────────────
JWT_SECRET="change-this-secret-in-production-to-something-random-and-long"

# ─────────────── Сервер ───────────────
PORT=4000
NODE_ENV=production

# Адрес фронтенда — сюда бэк делает редиректы после OAuth
FRONTEND_URL=https://your-frontend.example.com

# ─────────────── Google OAuth ───────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend.example.com/auth/google/callback

# ─────────────── GitHub OAuth ───────────────
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-backend.example.com/auth/github/callback

# ─────────────── Yandex OAuth ───────────────
# https://oauth.yandex.ru
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=https://your-backend.example.com/auth/yandex/callback

# ─────────────── ЮKassa ───────────────
# https://yookassa.ru/my
UKASSA_SHOP_ID=
UKASSA_SECRET_KEY=
# URL возврата после оплаты — это страница /premium на фронте
UKASSA_RETURN_URL=https://your-frontend.example.com/premium?payment=success
